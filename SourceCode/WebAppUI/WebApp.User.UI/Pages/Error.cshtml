@page
@model ErrorModel
@{
	ViewData["Title"] = "Error";
}

<!--Breadcrumb Row-->
<div class="row mb-4">
	<div class="col-12">
		<ol class="breadcrumb my-0">
			<li class="breadcrumb-item"><a asp-page="/Index" class="breadcrumb-link">Home</a></li>
			<li class="breadcrumb-item active">@ViewData["Title"]</li>
		</ol>
	</div>
</div>
<!--Breadcrumb Row-->

<!--Page Header Row-->
<div class="row mb-4">
	<div class="col-12">
		<div class="PageHeader">@ViewData["Title"]</div>
	</div>
</div>
<!--Page Header Row-->

<!--Content Row-->
<div class="row">
	<div class="col-12">
		<div class="ContentSection mb-3">An error occurred while processing the request.</div>

		<p class="mb-0">
			<strong>Error Message:</strong><br>
			@Html.Raw(Model.ErrorMessage)
		</p>

		<environment include="Development">
			<p class="mt-3 mb-0">
				<strong>Error Details:</strong><br>
				<code>@Model.StackTrace</code>
			</p>
		</environment>
	</div>
</div>
<!--Content Row-->