{
  "DetailedErrors": true,
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "BaseAPIAddress": "https://localhost:44301/",
  "Hash": {
    "HashKey": "HashSuperSecretKeyGoeshere"
  },
  "SiteSettings": {
    "PageSize": 5
  },
  "Serilog": {
    "Using": [],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [ "FromLogContext", "WithMachineName", "WithProcessId", "WithThreadId" ],
    "WriteTo": [
      {
        "Name": "MSSqlServer",
        "Args": {
          "connectionString": "Data Source=(localdb)\\ProjectModels;Initial Catalog=WebApp;Integrated Security=True;Connect Timeout=30;Encrypt=True;Trust Server Certificate=False;Application Intent=ReadWrite;",

          //"connectionString": "Data Source=.\\SQLExpress2019;Initial Catalog=WebApp;Password=sa2019.N;User ID=sa;Integrated Security = false;TrustServerCertificate=True;",
          "tableName": "ApplicationLogs",
          "autoCreateSqlTable": true
        }
      },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://localhost:8081"
        }
      }
    ]
  }
}